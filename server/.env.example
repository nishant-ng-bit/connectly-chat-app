# Server-only secrets. Configure these in your deployment provider, never in client env.
PORT=3001
CLIENT_URL=https://your-frontend-domain.example.com
DATABASE_URL=mongodb+srv://USER:PASSWORD@HOST/DATABASE
JWT_SECRET=replace-with-a-long-random-secret

# Email/OTP
MAIL_USER=your-email@example.com
MAIL_PASS=your-app-password
MAIL_FROM=your-email@example.com
# Optional: use these for non-Gmail SMTP providers
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Cloudinary media uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Optional AI features
GEMINI_API_KEY=your-gemini-api-key
